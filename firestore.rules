rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Core helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isSuperAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == "kinan88m@gmail.com"
      );
    }
    
    function isAdmin() {
      return isAuthenticated() && (
        isSuperAdmin() || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    match /users/{id} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        request.auth.uid == id || 
        isSuperAdmin() ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.companyId == resource.data.companyId)
      );
      allow delete: if isAuthenticated() && (
        isSuperAdmin() ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.companyId == resource.data.companyId)
      );
    }

    match /attendance/{id} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    match /projects/{id} {
      allow read: if isAuthenticated();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /shifts/{id} {
      allow read: if isAuthenticated();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /settings/{id} {
      allow read: if isAuthenticated();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /holidays/{id} {
      allow read: if isAuthenticated();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /broadcasts/{id} {
      allow read: if isAuthenticated();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /payroll_adjustments/{id} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /companies/{id} {
      allow read: if true; // Allowed so anyone can check company existence during signup
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        isSuperAdmin() || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.companyId == id && (
          (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['plan', 'employeeLimit', 'subscriptionStatus', 'paypalSubscriptionId', 'paymentProvider', 'ownerId'])) ||
          (
            request.resource.data.plan == 'free' &&
            request.resource.data.employeeLimit == 5 &&
            request.resource.data.subscriptionStatus == 'active'
          )
        ))
      );
      allow delete: if isSuperAdmin();
    }

    match /config/{docId} {
      allow read, write: if false;
    }
  }
}
