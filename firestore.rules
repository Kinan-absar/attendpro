rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Core helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isSuperAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == "kinan88m@gmail.com"
      );
    }
    
    function isAdmin() {
      return isAuthenticated() && (
        isSuperAdmin() || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().role == 'admin')
      );
    }
    
    // Checks if the document belongs to the authenticated user's company
    function belongsToCompany(companyId) {
      return isAuthenticated() && (
        isSuperAdmin() || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().companyId == companyId)
      );
    }

    match /users/{id} {
      allow read: if isAuthenticated() && (
        request.auth.uid == id || 
        (isAdmin() && belongsToCompany(resource.data.companyId))
      );
      allow create: if isAuthenticated() && (
        request.auth.uid == id || 
        (isAdmin() && belongsToCompany(request.resource.data.companyId))
      );
      allow update: if isAuthenticated() && (
        (request.auth.uid == id && request.resource.data.companyId == resource.data.companyId) || 
        (isAdmin() && (belongsToCompany(resource.data.companyId) || belongsToCompany(request.resource.data.companyId)))
      );
      allow delete: if isAdmin() && belongsToCompany(resource.data.companyId);
    }

    match /attendance/{id} {
      allow read: if isAuthenticated() && (
        (resource.data.userId == request.auth.uid) || 
        (isAdmin() && belongsToCompany(resource.data.companyId))
      );
      allow create: if isAuthenticated() && (
        belongsToCompany(request.resource.data.companyId) && 
        request.resource.data.userId == request.auth.uid
      );
      allow update: if isAuthenticated() && (
        (resource.data.userId == request.auth.uid && belongsToCompany(resource.data.companyId) && request.resource.data.companyId == resource.data.companyId) || 
        (isAdmin() && (belongsToCompany(resource.data.companyId) || belongsToCompany(request.resource.data.companyId)))
      );
      allow delete: if isAdmin() && belongsToCompany(resource.data.companyId);
    }

    match /projects/{id} {
      allow read: if isAuthenticated() && belongsToCompany(resource.data.companyId);
      allow create: if isAdmin() && belongsToCompany(request.resource.data.companyId);
      allow update: if isAdmin() && (belongsToCompany(resource.data.companyId) || belongsToCompany(request.resource.data.companyId));
      allow delete: if isAdmin() && belongsToCompany(resource.data.companyId);
    }

    match /shifts/{id} {
      allow read: if isAuthenticated() && belongsToCompany(resource.data.companyId);
      allow create: if isAdmin() && belongsToCompany(request.resource.data.companyId);
      allow update: if isAdmin() && (belongsToCompany(resource.data.companyId) || belongsToCompany(request.resource.data.companyId));
      allow delete: if isAdmin() && belongsToCompany(resource.data.companyId);
    }

    match /settings/{id} {
      allow read: if isAuthenticated() && belongsToCompany(resource.data.companyId);
      allow create: if isAdmin() && belongsToCompany(request.resource.data.companyId);
      allow update: if isAdmin() && (belongsToCompany(resource.data.companyId) || belongsToCompany(request.resource.data.companyId));
      allow delete: if isAdmin() && belongsToCompany(resource.data.companyId);
    }

    match /holidays/{id} {
      allow read: if isAuthenticated() && belongsToCompany(resource.data.companyId);
      allow create: if isAdmin() && belongsToCompany(request.resource.data.companyId);
      allow update: if isAdmin() && (belongsToCompany(resource.data.companyId) || belongsToCompany(request.resource.data.companyId));
      allow delete: if isAdmin() && belongsToCompany(resource.data.companyId);
    }

    match /broadcasts/{id} {
      allow read: if isAuthenticated() && belongsToCompany(resource.data.companyId);
      allow create: if isAdmin() && belongsToCompany(request.resource.data.companyId);
      allow update: if isAdmin() && (belongsToCompany(resource.data.companyId) || belongsToCompany(request.resource.data.companyId));
      allow delete: if isAdmin() && belongsToCompany(resource.data.companyId);
    }

    match /payroll_adjustments/{id} {
      allow read: if isAdmin() && belongsToCompany(resource.data.companyId);
      allow create: if isAdmin() && belongsToCompany(request.resource.data.companyId);
      allow update: if isAdmin() && (belongsToCompany(resource.data.companyId) || belongsToCompany(request.resource.data.companyId));
      allow delete: if isAdmin() && belongsToCompany(resource.data.companyId);
    }

    match /companies/{id} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAdmin() && belongsToCompany(id);
    }
  }
}
