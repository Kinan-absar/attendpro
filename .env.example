# Application Environment Mode (values: development, sandbox_test, live_production)
# - development: Allows webhook simulations, relaxes webhook signature verification if PAYPAL_WEBHOOK_ID is missing.
# - sandbox_test: Strict signature verification using PayPal sandbox webhook, disables webhook simulation/simulator endpoints.
# - live_production: Strict signature verification for production, disables simulator endpoints completely.
APP_ENV=development

